# Copy this file to `.env` and fill in the values.

# ShowBox mobile API (Triple-DES request signing)
SHOWBOX_BASE_URL=https://mbpapi.shegu.net/api/api_client/index/
SHOWBOX_APP_KEY=moviebox
SHOWBOX_IV=
SHOWBOX_KEY=

# FebBox file shares / stream links
FEBBOX_BASE_URL=https://www.febbox.com
FEBBOX_COOKIE=

# Cloudflare Worker proxy used to reach ShowBox/FebBox
PROXY_BASE=https://lunaissohot.lunastar0003.workers.dev/?destination=

# TMDB browse/discovery (proxied via /api/tmdb/*). A public key ships as the
# default, so these are optional — override only to use your own key.
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_API_KEY=

# HTTP server
PORT=3000
